rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPartner() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';
    }

    function isCustomer() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer';
    }

    match /users/{uid} {
      allow read, update: if isOwner(uid);
      allow create: if signedIn() && request.auth.uid == uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isPartner() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isPartner() && resource.data.sellerId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isPartner();
    }

    match /cart/{itemId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /wishlist/{itemId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /orders/{orderId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.uid == request.auth.uid ||
        request.auth.uid in resource.data.sellerIds
      );
      allow update: if false;
      allow delete: if false;
    }

    match /walletTransactions/{txId} {
      allow read, create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
